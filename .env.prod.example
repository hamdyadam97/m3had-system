# ============================================
# ملف إعدادات البيئة الإنتاجية - .env.prod
# ============================================
# انسخ هذا الملف وسميه .env.prod ثم عدل القيم

# ============================================
# Django Core
# ============================================
SECRET_KEY=change-this-to-a-50-char-random-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1

# ============================================
# Superuser Auto-Creation (optional)
# ============================================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_PASSWORD=change-strong-admin-password

# ============================================
# قاعدة البيانات (PostgreSQL داخل Docker)
# ============================================
DB_NAME=institute_db
DB_USER=institute_user
DB_PASSWORD=change-strong-db-password

# أو يمكنك استخدام DATABASE_URL مباشرة (Docker Compose يملأها تلقائياً)
# DATABASE_URL=postgres://institute_user:change-strong-db-password@db:5432/institute_db

# ============================================
# إعدادات البريد الإلكتروني (Brevo)
# ============================================
EMAIL_HOST_USER=your-email@smtp-brevo.com
EMAIL_HOST_PASSWORD=your-brevo-smtp-key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# إعدادات واتساب (UltraMsg أو CallMeBot)
# ============================================
WHATSAPP_API_TOKEN=your-ultramsg-token
WHATSAPP_INSTANCE_ID=your-instance-id
CALLMEBOT_API_KEY=your-callmebot-key

# ============================================
# إعدادات Celery & Redis (داخل Docker)
# ============================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================
# إعدادات إضافية (اختياري)
# ============================================
TIME_ZONE=Africa/Cairo
LANGUAGE_CODE=ar
