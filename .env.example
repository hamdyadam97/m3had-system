
# ============================================
# ملف الإعدادات الحساسة - .env
# ============================================
# انسخ هذا الملف وسميه .env ثم عدل القيم

# ============================================
# Django Secret Key (ضروري للـ Production)
# ============================================
# SECRET_KEY=your-secret-key-here-change-in-production
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ============================================
# قاعدة البيانات (اختر واحدة)
# ============================================

# --- Option 1: SQLite (للتطوير المحلي) ---
# لا تضف شيء - SQLite هو الافتراضي

# --- Option 2: PostgreSQL (للـ Production) ---
# طريقة 1: استخدام DATABASE_URL
# DATABASE_URL=postgres://user:password@host:port/dbname

# طريقة 2: إعدادات منفصلة
# DB_NAME=institute_db
# DB_USER=institute_user
# DB_PASSWORD=strong_password_here
# DB_HOST=localhost
# DB_PORT=5432

# ============================================
# إعدادات البريد الإلكتروني (Brevo)
# ============================================
EMAIL_HOST_USER=a651ba001@smtp-brevo.com
EMAIL_HOST_PASSWORD=xsmtpsib-d6d2f7884dea4efe5603751b7f0297ad243d3a4b8374e33134eda1acfd5e3bad-lLGEKYMGpAr6VvfQ
DEFAULT_FROM_EMAIL=hamdy.adam@ararhni.com


# ============================================
# إعدادات واتساب (UltraMsg أو CallMeBot)
# ============================================
# بيانات UltraMsg من لوحة التحكم الخاصة بك
WHATSAPP_API_TOKEN=your-ultramsg-token
WHATSAPP_INSTANCE_ID=your-instance-id

# أو لو تستخدم CallMeBot (بديل مجاني)
CALLMEBOT_API_KEY=your-callmebot-key

# ============================================
# إعدادات Celery & Redis
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# إعدادات إضافية (اختياري)
# ============================================
# TIME_ZONE=Africa/Cairo
# LANGUAGE_CODE=ar
